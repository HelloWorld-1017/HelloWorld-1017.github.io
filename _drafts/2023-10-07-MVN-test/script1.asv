% https://real-statistics.com/multivariate-statistics/multivariate-normal-distribution/multivariate-normality-testing/
clc,clear,close all

rng(1)


load fisheriris.mat
clear species 
meas = meas(1:50,1:3);

mu = mean(meas);
Sigma = cov(meas);

mvnrnd(mu,Sigma)

[n,k] = size(meas);

Sigma_hat = cov(meas,1);

